{
  "expo": {
    "name": "thoughts",
    "slug": "thoughts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "thoughts",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#EAF2F8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.otto.thoughts",
      "buildNumber": "3"
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Allow thoughts to access your microphone to record audio."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Erlaube thoughts, deinen Standort zu verwenden, damit jeder thought automatisch Stadt und Stadtteil erhält."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
